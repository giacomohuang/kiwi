#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/giacomohuang/projects/kiwi/src/node_modules/.pnpm/skew@0.9.19/node_modules/skew/node_modules:/Users/giacomohuang/projects/kiwi/src/node_modules/.pnpm/skew@0.9.19/node_modules:/Users/giacomohuang/projects/kiwi/src/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/giacomohuang/projects/kiwi/src/node_modules/.pnpm/skew@0.9.19/node_modules/skew/node_modules:/Users/giacomohuang/projects/kiwi/src/node_modules/.pnpm/skew@0.9.19/node_modules:/Users/giacomohuang/projects/kiwi/src/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../skew/skewc" "$@"
else
  exec node  "$basedir/../skew/skewc" "$@"
fi
